{
  "name": "archicrm-desktop",
  "version": "1.0.1",
  "description": "ArchiCRM Desktop — offline-first",
  "main": "main.js",
  "author": "ArchiCRM <contact@crm.archi>",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "generate-icon": "node scripts/generate-icon.js",
    "rebuild-sqlite": "npx @electron/rebuild -f -w better-sqlite3",
    "build:react": "cd ../client && npm run build",
    "build": "npm run rebuild-sqlite && npm run build:react && electron-builder --win --x64",
    "build:fast": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac --universal"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3",
    "sharp": "^0.33.4"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "ws": "^8.20.1"
  },
  "build": {
    "appId": "ma.crm.archicrm.desktop",
    "productName": "ArchiCRM",
    "copyright": "Copyright © 2025 ArchiCRM",
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "db/**/*.js",
      "sync/**/*.js",
      "node_modules/**/*",
      "!node_modules/sharp/**/*",
      "!node_modules/.cache/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/@electron/rebuild/**/*"
    ],
    "extraResources": [
      {
        "from": "../client/dist",
        "to": "client/dist",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico",
      "artifactName": "ArchiCRM-Setup.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ArchiCRM",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "mac": {
      "category": "public.app-category.business",
      "target": [{ "target": "dmg", "arch": ["universal"] }],
      "icon": "assets/icon.icns",
      "artifactName": "ArchiCRM-Setup.dmg",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "ArchiCRM",
      "window": { "width": 540, "height": 360 },
      "contents": [
        { "x": 150, "y": 200, "type": "file" },
        { "x": 390, "y": 200, "type": "link", "path": "/Applications" }
      ]
    },
    "publish": null
  }
}
