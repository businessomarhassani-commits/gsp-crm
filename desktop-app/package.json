{
  "name": "archicrm",
  "version": "1.0.0",
  "description": "ArchiCRM — CRM professionnel pour architectes marocains",
  "main": "main.js",
  "author": "ArchiCRM <contact@crm.archi>",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "generate-icon": "node scripts/generate-icon.js",
    "build": "npm run generate-icon && electron-builder --win --x64",
    "build:dir": "npm run generate-icon && electron-builder --win --x64 --dir"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "sharp": "^0.33.4"
  },
  "build": {
    "appId": "ma.crm.archicrm",
    "productName": "ArchiCRM",
    "copyright": "Copyright © 2025 ArchiCRM",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "assets/**/*",
      "!assets/icon.svg",
      "!node_modules/sharp/**/*",
      "node_modules/sharp/build/Release/**/*",
      "node_modules/sharp/lib/**/*",
      "node_modules/sharp/package.json"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "ArchiCRM-Setup-${version}.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ArchiCRM",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false
    },
    "publish": null
  }
}
